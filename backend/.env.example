# =============================================================================
# Backend Environment Configuration
# =============================================================================
# Copy this file to .env and update values as needed
#
# For Kubernetes deployment, these values are configured via Helm values.yaml
# This file is for running the backend directly outside Kubernetes
# =============================================================================

# Server Configuration
SERVER_PORT=8080
GRPC_PORT=9090
ENVIRONMENT=development
LOG_LEVEL=debug

# JWT Authentication (REQUIRED - min 32 characters)
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters

# Database Configuration
# Option 1: Full connection URL (recommended)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/scaledtest?sslmode=disable

# Option 2: Individual components (used if DATABASE_URL not set)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=scaledtest
DB_SSL_MODE=disable

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Kubernetes Configuration (for test job execution)
# Leave empty to use default kubeconfig (~/.kube/config)
# KUBECONFIG=/path/to/custom/kubeconfig

# Artifact Storage
# Path where test artifacts are stored (must match K8s PVC mount)
ARTIFACT_STORAGE_PATH=/tmp/scaledtest/artifacts
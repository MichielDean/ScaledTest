# Dependencies (will be installed fresh in containers)
node_modules
**/node_modules
frontend/node_modules

# Build outputs
.next
dist
build
coverage

# Git and IDE
.git
.vscode
.github
.idea
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Logs
*.log
logs


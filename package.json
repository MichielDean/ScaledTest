{
  "name": "scaledtest",
  "version": "1.0.0",
  "description": "A Go backend with React/Vite frontend",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build": "npm run format && npm run lint",
    "dev": "tilt up",
    "dev:down": "tilt down",
    "helm:install": "helm install scaledtest ./deploy/helm/scaledtest -f ./deploy/helm/scaledtest/values-dev.yaml --set postgresql.primary.initdb.scriptsConfigMap=scaledtest-postgres-initdb --wait --timeout 5m",
    "helm:uninstall": "helm uninstall scaledtest",
    "helm:upgrade": "helm upgrade scaledtest ./deploy/helm/scaledtest -f ./deploy/helm/scaledtest/values-dev.yaml --set postgresql.primary.initdb.scriptsConfigMap=scaledtest-postgres-initdb --wait --timeout 5m",
    "k8s:status": "kubectl get pods,svc,jobs",
    "k8s:logs:backend": "kubectl logs -f -l app.kubernetes.io/component=backend,app.kubernetes.io/instance=scaledtest",
    "k8s:logs:frontend": "kubectl logs -f -l app.kubernetes.io/component=frontend,app.kubernetes.io/instance=scaledtest",
    "k8s:port-forward": "kubectl port-forward svc/scaledtest-backend 8080:8080 & kubectl port-forward svc/scaledtest-frontend 5173:80",
    "db:shell": "kubectl exec -it scaledtest-postgresql-0 -- psql -U scaledtest scaledtest",
    "db:password": "kubectl get secret scaledtest-postgresql -o jsonpath='{.data.password}' | base64 -d && echo",
    "generate:types": "cd backend && make generate-types",
    "generate:ci": "cd backend && make generate-ci",
    "verify:generated": "cd backend && make verify-generated",
    "update-deps": "npx npm-check-updates -u && npm install",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md,yml,yaml,html}\" --log-level warn",
    "lint": "eslint .",
    "lint:frontend": "cd frontend && npm run lint",
    "test:backend:unit": "cd backend && make test-unit",
    "test:backend:integration": "cd backend && make test-integration",
    "test:backend": "cd backend && make test",
    "test:e2e": "cd frontend && npm test",
    "test:e2e:skip-servers": "cd frontend && npm run test:skip-servers",
    "test:all": "bash test-all.sh",
    "test:dogfood": "bash test-all.sh",
    "send-test-results": "npx tsx scripts/send-test-results.ts",
    "build:images": "npm run build:playwright && npm run build:jest",
    "prepare": "husky",
    "postinstall": "husky && npx playwright install chromium"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.13.2",
    "get-port": "^7.1.0",
    "pino": "^10.1.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.56.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.1",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "@types/wait-on": "^5.3.4",
    "@typescript-eslint/eslint-plugin": "^8.46.4",
    "@typescript-eslint/parser": "^8.46.4",
    "axe-playwright": "^2.2.2",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-unused-imports": "^4.3.0",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.2.0",
    "jest-ctrf-json-reporter": "^0.0.10",
    "jest-environment-jsdom": "^30.2.0",
    "jest-environment-node": "^30.2.0",
    "json-schema-to-typescript": "^15.0.4",
    "lint-staged": "^16.2.6",
    "pino-pretty": "^13.1.2",
    "playwright": "^1.56.1",
    "prettier": "^3.6.2",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "uuid": "^9.0.1",
    "wait-on": "^9.0.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,md,yml,yaml,html}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "glob": "10.4.5",
    "nyc": {
      "glob": "^7.2.3"
    }
  }
}
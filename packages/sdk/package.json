{
  "name": "@scaledtest/sdk",
  "version": "0.1.0",
  "description": "TypeScript/JavaScript client for the ScaledTest API — upload reports, query results, manage test executions",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.esm.json && tsc -p tsconfig.cjs.json",
    "typecheck": "tsc --noEmit",
    "test": "jest"
  },
  "keywords": [
    "scaledtest",
    "testing",
    "ctrf",
    "ci",
    "sdk",
    "typescript"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.1.3",
    "ts-jest": "^29.4.1",
    "typescript": "^5.9.2"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MichielDean/ScaledTest",
    "directory": "packages/sdk"
  }
}
